# ─── LinkedIn credentials ─────────────────────────────────────────────────────
# Required for automated applying. Stored locally, never committed (gitignored).
LINKEDIN_EMAIL=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password

# ─── LLM providers ────────────────────────────────────────────────────────────
# The pipeline calls LLMs in this priority order:
#
# TEXT prompts (profile extraction, scoring, resume tailoring):
#   1. codex CLI      — OpenAI Codex session, zero key needed
#   2. claude CLI     — Claude Code session, zero key needed
#   3. openclaw CLI   — openclaw session, zero key needed
#   4. NVIDIA NIM     — NVIDIA_API_KEY
#   5. Anthropic SDK  — ANTHROPIC_API_KEY fallback
#
# VISION prompts (external form screenshot analysis):
#   1. Anthropic SDK  — ANTHROPIC_API_KEY
#   2. Gemini API     — GEMINI_API_KEY
#   3. GitHub Copilot — GITHUB_TOKEN (requires active Copilot subscription)
#
# Uncomment whichever you have:
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...
# GITHUB_TOKEN=ghp_...

NVIDIA_API_KEY=nvapi-...
